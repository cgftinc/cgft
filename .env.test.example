# Integration test credentials — copy to .env.test and fill in real values.
# .env.test is gitignored; this example file is committed as a reference.
#
# Markers:
#   pytest -m integration   # live-backend adapter tests (fast, one backend)
#   pytest -m e2e           # full train(dry_run=True) through the
#                           # rollout-server (autobots.cgft.io). Slower,
#                           # costs LLM tokens; not CI-appropriate.

# CGFT Platform — required for any e2e test. Create a user key at
# https://app.cgft.io/account/api-keys. Needed for dataset upload +
# autobots.cgft.io (rollout-server) remote validation.
CGFT_API_KEY=
CGFT_BASE_URL=https://app.cgft.io
CGFT_CORPUS_NAME=

# Braintrust (traces)
BT_API_KEY=
BT_PROJECT_ID=

# Turbopuffer (corpus backend)
TPUF_API_KEY=
TPUF_NAMESPACE=
TPUF_REGION=aws-us-east-1

# Pinecone (corpus backend). Tests assume the index is already populated
# with content-bearing metadata. Pinecone's hosted Inference API is used
# for embeddings by default (no extra creds needed).
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# Chroma Cloud (corpus backend)
# Sign up at https://trychroma.com, create a tenant + database, then paste
# creds + a collection name below. Tests assume the collection is already
# populated (wizard uses `populate_from_existing_collection`-style reads),
# so the suite doesn't create / tear down data.
CHROMA_CLOUD_API_KEY=
CHROMA_CLOUD_TENANT=
CHROMA_CLOUD_DATABASE=
CHROMA_CLOUD_COLLECTION=

# TODO: CGFT Platform (training jobs, blob storage, corpora API)
# CGFT_API_KEY=
# CGFT_BASE_URL=
